# NodeRoom runs fully with NO keys (deterministic in-memory engine + scripted agents).
# Keys only light up the LIVE paths (real Convex room + real LLM agents).

# Client (inlined into the browser bundle)
VITE_CONVEX_URL=

# Server-side (never exposed) — light up live agents
CONVEX_DEPLOYMENT=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_FREE_AUTO_LIMIT=8
OPENROUTER_FREE_MODEL_CACHE_MS=600000
AGENT_MODEL=gpt-5.4-nano
AGENT_ACTION_BUDGET_MS=600000
AGENT_ACTION_RESERVE_MS=30000
AGENT_CONTEXT_MAX_CHARS=24000
AGENT_CONTEXT_KEEP_RECENT=10

# Async free-auto job path (`/free`): sliced, checkpointed, and resumable.
FREE_AUTO_JOB_MODEL=openrouter/free-auto
FREE_AUTO_JOB_SLICE_BUDGET_MS=540000
FREE_AUTO_JOB_RESERVE_MS=30000
FREE_AUTO_JOB_MAX_STEPS_PER_SLICE=3
FREE_AUTO_JOB_CONTEXT_MAX_CHARS=24000
FREE_AUTO_JOB_CONTEXT_KEEP_RECENT=10

# Optional live `/free` smoke (`npm run free-job:smoke`).
# These are room/member proof values from a real Convex room.
FREE_JOB_ROOM_ID=
FREE_JOB_ARTIFACT_ID=
FREE_JOB_ACTOR_ID=
FREE_JOB_ACTOR_NAME=
FREE_JOB_ACTOR_TOKEN=
FREE_JOB_GOAL=
FREE_JOB_TIMEOUT_MS=900000

# Optional server-side parser model overrides.
PROVIDER_PARSER_GEMINI_MODEL=gemini-3.5-flash
PROVIDER_PARSER_OPENAI_MODEL=gpt-5.4-mini
PROVIDER_PARSER_ANTHROPIC_MODEL=claude-haiku-4-5
PROVIDER_PARSER_OPENROUTER_MODEL=openai/gpt-4o-mini
